<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="CrossBrowserTestSuite" parallel="none" configfailurepolicy="continue">
    <groups>
        <define name="AllGroups">
            <include name="Positive"/>
        </define>
        <define name="AllGroups">
            <include name="Negative"/>
        </define>
        <define name="AllGroups">
            <include name="Smoke"/>
        </define>
        <define name="AllGroups">
            <include name="Regression"/>
        </define>
        <define name="AllGroups">
            <include name="Security"/>
        </define>
    </groups>

    <listeners>
        <listener class-name="listeners.RetryTransformer"/>
    </listeners>

    <test name="AllTests-Chrome">
        <parameter name="browser" value="chrome"/>
        <packages>
            <package name="tests.ui"/>
        </packages>
    </test>

    <test name="AllTests-Firefox">
        <parameter name="browser" value="firefox"/>
        <packages>
            <package name="tests.ui"/>
        </packages>
    </test>
</suite>