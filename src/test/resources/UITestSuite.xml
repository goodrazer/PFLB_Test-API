<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<suite name="UITestSuite" parallel="none" configfailurepolicy="continue">

    <listeners>
        <listener class-name="listeners.RetryTransformer"/>
    </listeners>

    <test name="AllTests-Chrome">
        <parameter name="browser" value="chrome"/>
        <packages>
            <package name="tests.ui.allPost"/>
            <package name="tests.ui.base"/>
            <package name="tests.ui.cars"/>
            <package name="tests.ui.houses"/>
            <package name="tests.ui.login"/>
            <package name="tests.ui.users"/>
        </packages>
    </test>

</suite>