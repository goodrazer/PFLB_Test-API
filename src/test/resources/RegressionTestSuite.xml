<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<suite name="Regression Test Suite">

    <listeners>
        <listener class-name="listeners.RetryTransformer"/>
    </listeners>

    <test name="Regression Tests">
        <parameter name="browser" value="chrome"/>
        <groups>
            <run>
                <include name="Regression"/>
            </run>
        </groups>
        <packages>
            <package name="tests.ui.allPost"/>
            <package name="tests.ui.cars"/>
            <package name="tests.ui.houses"/>
            <package name="tests.ui.login"/>
            <package name="tests.ui.users"/>
        </packages>
    </test>

    <test name="Regression Tests Api">
        <groups>
            <run>
                <include name="Regression"/>
            </run>
        </groups>
        <packages>
            <package name="tests.api.cars"/>
            <package name="tests.api.users"/>
            <package name="tests.api.login"/>
        </packages>
    </test>

</suite>